{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write --list-different .",
    "prepare": "husky"
  },
  "dependencies": {
    "@artmizu/nuxt-prometheus": "3.0.1",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/icon": "2.2.2",
    "@nuxt/ui": "4.7.1",
    "@pinia/nuxt": "0.11.3",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "nuxt": "4.4.4",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "valibot": "1.4.0",
    "vue": "3.5.34",
    "vue-router": "5.0.6"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "17.0.2",
    "tailwindcss": "4.2.4"
  },
  "packageManager": "pnpm@11.0.9",
  "lint-staged": {
    "*.{js,ts,vue}": "pnpm lint:fix"
  }
}
