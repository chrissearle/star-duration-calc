{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write --list-different .",
    "prepare": "husky"
  },
  "dependencies": {
    "@artmizu/nuxt-prometheus": "3.0.3",
    "@nuxt/eslint": "1.16.0",
    "@nuxt/icon": "2.3.1",
    "@nuxt/ui": "4.10.0",
    "@pinia/nuxt": "1.0.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "nuxt": "4.5.0",
    "pinia": "4.0.2",
    "prettier": "3.9.6",
    "typescript": "6.0.3",
    "valibot": "1.4.2",
    "vue": "3.5.40",
    "vue-router": "5.2.0"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "tailwindcss": "4.3.3"
  },
  "packageManager": "pnpm@11.15.1",
  "lint-staged": {
    "*.{js,ts,vue}": "pnpm lint:fix"
  }
}